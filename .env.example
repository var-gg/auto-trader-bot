# Public-safe example environment file for local development
# Copy to .env and fill with your own values. Never commit real secrets.

# --- Core runtime ---
CLOUD_CODE_ENV=false
DB_SCHEMA=trading

# --- Local database option (fallback) ---
# Use either DB_URL or the DB_USER/DB_PASS/DB_NAME trio below.
DB_URL=postgresql://username:password@127.0.0.1:5432/database

# --- Preferred DB env split ---
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=your_db_name
PROXY_HOST=127.0.0.1
PROXY_PORT=5432
INSTANCE_CONNECTION_NAME=your-project:your-region:your-instance

# --- LLM / data providers ---
OPENAI_API_KEY=your_openai_api_key
FRED_API_KEY=your_fred_api_key
DART_API_KEY=

# --- KIS broker config ---
KIS_VIRTUAL=false
KIS_APPKEY=your_kis_appkey
KIS_APPSECRET=your_kis_appsecret
KIS_CANO=your_8digit_account_number
KIS_ACNT_PRDT_CD=01
KIS_VIRTUAL_APPKEY=your_virtual_kis_appkey
KIS_VIRTUAL_APPSECRET=your_virtual_kis_appsecret
KIS_VIRTUAL_CANO=your_virtual_8digit_account_number

# --- General tuning ---
MAX_CONTENT_RETRY=2
DAILY_OVERLAP_DAYS=3
KIS_TOKEN_TTL=3300
KIS_REQUEST_INTERVAL_MS=120
KIS_TOKEN_SKEW_SECONDS=60

# --- News risk multiplier ---
ENABLE_NEWS_RISK_MULTIPLIER=false
NEWS_RISK_MAX_MULTIPLIER=3.0
NEWS_RISK_DEFAULT_TTL_MIN=120
NEWS_RISK_PROVIDER=openai
NEWS_RISK_MODEL=gpt-5-nano
NEWS_RISK_API_KEY=
NEWS_RISK_MIN_HEADLINES=8
NEWS_RISK_GLOBAL_BLEND_WEIGHT=0.35
ENABLE_NEWS_BULL_MULTIPLIER=false
NEWS_BULL_MAX_MULTIPLIER=1.8

# --- Logging ---
GPT_LOG_ENABLED=true
GPT_LOG_MAX_PROMPT_CHARS=16000
GPT_LOG_MAX_RESPONSE_CHARS=16000

# --- Macro / prompt params ---
MACRO_PROMPT_POINTS_PER_SERIES=6
THEME_FULL_SCORE_DEFAULT=1.0
NEWS_TIME_WINDOW_HOURS_DEFAULT=24
